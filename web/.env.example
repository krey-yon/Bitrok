# Bitrok web dashboard environment
# Copy to .env.local for local development or configure these values in Vercel.

# PostgreSQL used by Better Auth and Prisma.
DATABASE_URL=postgresql://bitrok:bitrok@localhost:5432/bitrok

# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-at-least-32-random-bytes
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth application. Request the read:user and user:email scopes.
# Local callback: http://localhost:3000/api/auth/callback/github
# Production callback: https://bitrok.tech/api/auth/callback/github
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret

# Must be identical to BITROK_JWT_SECRET on the Go relay.
BITROK_JWT_SECRET=replace-with-at-least-32-random-bytes

# Go relay API used by server-side dashboard calls.
BITROK_SERVER_URL=http://localhost:8080

# Optional shared Redis. Enables revocable opaque CLI tokens and distributed
# web rate limiting. Use the exact same URL on the relay deployment.
# BITROK_REDIS_URL=rediss://default:password@example.upstash.io:6379
# UPSTASH_REDIS_KEY is supported only as a legacy alias for BITROK_REDIS_URL.

# Optional Prisma pool tuning for serverless or shared PostgreSQL providers.
# PRISMA_CONNECTION_LIMIT=5
# PRISMA_POOL_TIMEOUT=15
# PRISMA_CONNECT_TIMEOUT=10

# Set to true only when the relay is running locally and BITROK_SERVER_URL is
# intentionally omitted.
# NEXT_PUBLIC_USE_LOCALHOST=false

# Legal and support contacts. Use monitored mailboxes in production.
SECURITY_CONTACT_EMAIL=security@bitrok.tech
PRIVACY_CONTACT_EMAIL=privacy@bitrok.tech
NEXT_PUBLIC_SUPPORT_EMAIL=support@bitrok.tech

# Optional search and analytics integrations.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_DOMAIN=https://cloud.umami.is
