# Bitrok Go relay environment
# Copy to .env for local use, or configure these values in Docker/Coolify.

# Required for dashboard-issued CLI JWTs. Generate with: openssl rand -hex 32
# This value must match web/.env.example BITROK_JWT_SECRET.
BITROK_JWT_SECRET=replace-with-at-least-32-random-bytes

# Relay identity and local persistence.
BITROK_PORT=8080
BITROK_DOMAIN=bitrok.tech
BITROK_DB_PATH=./bitrok.db
BITROK_LOG_LEVEL=info

# Leave legacy static tokens empty for new deployments.
BITROK_AUTH_TOKENS=

# Optional shared Redis for revocable opaque CLI tokens. Must match the web
# deployment when enabled. Use redis:// or rediss://, not an HTTP URL.
# BITROK_REDIS_URL=rediss://default:password@example.upstash.io:6379
# UPSTASH_REDIS_KEY is supported only as a legacy alias for BITROK_REDIS_URL.

# JWT claim validation. These must match the web/CLI token contract.
BITROK_JWT_ISSUER=bitrok
BITROK_JWT_AUDIENCE=bitrok-cli

# Proxy trust and WebSocket origin policy. Enable proxy headers only when the
# relay is reachable exclusively through your trusted TLS reverse proxy.
BITROK_TRUST_PROXY_HEADERS=false
BITROK_ALLOW_INSECURE_WS=false

# Optional TLS when the relay terminates TLS itself. Usually TLS belongs to the
# reverse proxy, so leave both unset when using Coolify/Traefik.
# BITROK_TLS_CERT=/path/to/cert.pem
# BITROK_TLS_KEY=/path/to/key.pem

# Request and account limits.
# BITROK_MAX_REQUEST_BODY_BYTES=1048576
BITROK_MAX_TUNNELS_PER_USER=25
BITROK_LOG_RETENTION_HOURS=168

# HTTP server timeouts in seconds.
# BITROK_READ_TIMEOUT=10
# BITROK_WRITE_TIMEOUT=30
# BITROK_IDLE_TIMEOUT=120
# BITROK_READ_HEADER_TIMEOUT=5
# BITROK_SHUTDOWN_TIMEOUT=15

# Control-plane rate limiter. Visitor proxy traffic is not rate limited here.
# BITROK_RATE_LIMIT_CAPACITY=600
# BITROK_RATE_LIMIT_WINDOW=60

# CLI control WebSocket limits and timeouts.
# Must remain at least 16 MB for the current buffered relay protocol.
# BITROK_WS_MAX_MESSAGE_SIZE_MB=16
# BITROK_WS_HELLO_TIMEOUT_SEC=10
# BITROK_WS_PING_INTERVAL_SEC=30
# BITROK_WS_READ_TIMEOUT_SEC=60
# BITROK_WS_WRITE_TIMEOUT_SEC=10

# SQLite connection pool. The supported relay topology uses one process-local
# SQLite writer and one relay replica.
# BITROK_DB_MAX_OPEN_CONNS=1
# BITROK_DB_MAX_IDLE_CONNS=1
# BITROK_DB_CONN_LIFETIME=300
# BITROK_DB_CONN_IDLE_TIME=120

# Optional Docker Compose build metadata; this is not a runtime secret.
# BITROK_VERSION=dev
