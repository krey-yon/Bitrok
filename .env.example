# bitrok-server — Required secrets (copy this to .env and fill in values)

# ── Authentication ──
# Optional comma-separated legacy tokens. Leave empty for new deployments.
BITROK_AUTH_TOKENS=

# JWT secret for validating tokens from the Vercel web dashboard
# Generate with: openssl rand -hex 32
BITROK_JWT_SECRET=replace-with-at-least-32-random-bytes

# Optional Redis URL shared with the web app for revocable opaque CLI keys.
# BITROK_REDIS_URL=rediss://default:password@example.upstash.io:6379

# ── Web dashboard (Vercel) ──
# These values must be configured in the web project as well as the relay
# where marked. Never commit a real .env file.
DATABASE_URL=postgresql://user:password@host:5432/bitrok
BETTER_AUTH_SECRET=replace-with-at-least-32-random-bytes
BETTER_AUTH_URL=https://bitrok.tech
NEXT_PUBLIC_APP_URL=https://bitrok.tech
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret
BITROK_SERVER_URL=https://api.bitrok.tech
# BITROK_REDIS_URL must be the same URL on both projects when opaque CLI keys
# or distributed rate limiting are enabled.
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_DOMAIN=https://cloud.umami.is
SECURITY_CONTACT_EMAIL=security@bitrok.tech
PRIVACY_CONTACT_EMAIL=privacy@bitrok.tech
NEXT_PUBLIC_SUPPORT_EMAIL=support@bitrok.tech

# ── Server config ──
BITROK_PORT=8080
BITROK_DOMAIN=bitrok.tech
BITROK_LOG_LEVEL=info
# BITROK_LOG_RETENTION_HOURS=168
# BITROK_MAX_TUNNELS_PER_USER=25

# ── Timeouts (seconds) ──
# BITROK_READ_TIMEOUT=10
# BITROK_WRITE_TIMEOUT=30
# BITROK_IDLE_TIMEOUT=120
# BITROK_READ_HEADER_TIMEOUT=5
# BITROK_SHUTDOWN_TIMEOUT=15

# ── Rate limiter (control-plane only: /api/* and /tunnel/* — NOT visitor proxy) ──
# Burst capacity and window (seconds). Steady rate ≈ capacity/window per second.
# BITROK_RATE_LIMIT_CAPACITY=600
# BITROK_RATE_LIMIT_WINDOW=60

# ── WebSocket ──
# Must remain at least 16 MB for the current buffered relay protocol.
# BITROK_WS_MAX_MESSAGE_SIZE_MB=16
# BITROK_WS_HELLO_TIMEOUT_SEC=10
# BITROK_WS_PING_INTERVAL_SEC=30
# BITROK_WS_READ_TIMEOUT_SEC=60
# BITROK_WS_WRITE_TIMEOUT_SEC=10

# ── SQLite pool ──
# BITROK_DB_MAX_OPEN_CONNS=1
# BITROK_DB_MAX_IDLE_CONNS=1
# BITROK_DB_CONN_LIFETIME=300
# BITROK_DB_CONN_IDLE_TIME=120

# ── TLS (optional) ──
# BITROK_TLS_CERT=/path/to/cert.pem
# BITROK_TLS_KEY=/path/to/key.pem
